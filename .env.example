# Copy to .env for local dev. On Render these are set as service env vars.

# Leave unset locally to use SQLite (sqlite:///pa_fabs.db).
# On Render this is injected from the managed Postgres instance.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Required in any deployed env. Generate one: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me

# Comma-separated allowed CORS origins (the deployed frontend URL).
# Use * for local dev only.
ALLOWED_ORIGINS=*
